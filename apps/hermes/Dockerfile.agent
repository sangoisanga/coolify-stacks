# Coolify variant: hermes-agent with firecrawl-py baked into the venv
#
# The stock agent image keeps /opt/hermes as an immutable root-owned tree.
# This derived image temporarily re-adds write permission to install
# firecrawl-py into the existing venv, then locks it back down.

FROM nousresearch/hermes-agent:latest

LABEL maintainer="NousResearch"
LABEL description="Hermes Agent with firecrawl-py pre-installed for gateway tool use"

USER root

# The stock image locks /opt/hermes to a-w (immutable for runtime safety).
# Re-add owner-write so we can install into the venv during the build.
# Only unlock the venv — the rest of /opt/hermes is unchanged from the base image.
RUN chmod -R u+w /opt/hermes/.venv

RUN /usr/local/bin/uv pip install --python /opt/hermes/.venv/bin/python firecrawl-py>=4.30 --no-cache-dir

# Lock the venv back down. The rest of /opt/hermes was never touched.
RUN chmod -R a-w /opt/hermes/.venv
